{"name":"SQL查询Agent","type":"ChatFlow","description":"自然语言提问→AI生成SQL→执行查询→结果解读。支持MySQL/PostgreSQL/SQLite","nodes":[{"id":"input","type":"chatInput","position":{"x":100,"y":100}},{"id":"sql_generator","type":"LLMChain","position":{"x":400,"y":100},"data":{"model":"deepseek-v4-pro","prompt":"根据用户问题生成SQL查询语句。数据库类型:{db_type}，表结构:{schema}\n\n用户问题:{question}\n\n只返回SQL语句，不要其他解释。","outputKey":"sql"}},{"id":"executor","type":"customNode","position":{"x":700,"y":100},"data":{"name":"sqlExecutor","db_type":"sqlite","inputKey":"sql","outputKey":"result"}},{"id":"interpreter","type":"LLMChain","position":{"x":1000,"y":100},"data":{"model":"qwen-turbo","prompt":"根据以下查询结果回答用户问题:\n\n用户问题:{question}\nSQL:{sql}\n查询结果:{result}\n\n请用通俗易懂的语言回答。","outputKey":"answer"}},{"id":"output","type":"chatOutput","position":{"x":1300,"y":100},"data":{"outputKey":"answer"}}],"edges":[],"author":"AgentHub-U"}